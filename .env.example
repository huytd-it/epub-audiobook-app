# EPUB Audiobook App — environment configuration
#
# Copy this file to `.env` and uncomment/edit the values you want to override.
# pydantic-settings reads `.env` from the current working directory at startup.
# Every setting has a default in app/config.py, so an empty `.env` is fine.
#
# Field names are uppercase; the mapping to the Settings fields is 1:1
# (DATA_ROOT -> data_root, ENABLE_WORKER -> enable_worker, etc.).
# `true` / `false` (case-insensitive) are accepted for booleans.

# ---------------------------------------------------------------------------
# Storage paths
# ---------------------------------------------------------------------------

# Root directory for runtime data (uploads, generated audio/video, sqlite db).
# Defaults to <project>/data. Subdirectories are created on first run.
# DATA_ROOT=/var/lib/epub-audiobook

# SQLite database file. Parent directory is created automatically.
# DB_PATH=/var/lib/epub-audiobook/app.db

# Rotating log file (10 MB x 5 backups). The console also gets every log line.
# LOG_PATH=/var/log/epub-audiobook/app.log

# ---------------------------------------------------------------------------
# Book / TTS defaults
# ---------------------------------------------------------------------------

# Default chapter count per patch when the user does not override it on upload.
# DEFAULT_PATCH_SIZE=10

# Soft cap on characters per TTS chunk (the engine splits long chapters on this).
# TTS_MAX_CHARS=400

# Fallback background image used for video generation when a book has none.
# DEFAULT_BACKGROUND_IMAGE=/opt/epub-audiobook/assets/default_background.jpg

# Use NVIDIA NVENC for the final mp4 encode. Set to `true` if ffmpeg was built
# with NVENC support and a compatible GPU is present. Falls back to libx264
# otherwise. Requires USE_NVENC=true to have any effect.
# USE_NVENC=false

# ---------------------------------------------------------------------------
# Background worker
# ---------------------------------------------------------------------------

# How often (seconds) the worker polls SQLite for the next pending patch.
# Lower = lower latency between upload and synthesis start, higher = more idle
# wake-ups. 2.0 is a sane default.
# WORKER_POLL_INTERVAL=2.0

# How long the FastAPI lifespan will wait for an in-flight patch to finish
# before forcing the worker task to cancel on shutdown. Bound so a hung TTS
# call (GPU stuck, model crash) cannot block server restart indefinitely.
# The next startup's recovery step rescues the patch left in 'processing'.
# WORKER_SHUTDOWN_TIMEOUT_SECONDS=300.0

# Toggle the entire background worker loop. When `false`, the server still
# boots, the DB is initialized, stuck patches and book_jobs are requeued —
# but no patch or book_job is ever claimed. Useful for dev with `uvicorn
# --reload` to silence the heartbeat noise; HTTP routes and /health stay
# fully functional (worker_state='disabled').
# ENABLE_WORKER=true

# Dev-only: reset ALL patches, book_jobs and books to a clean state on every
# startup (patches → pending, book_jobs → pending, books → ready, audio/video
# files → deleted). Good for resetting a broken dev DB. The backfill step is
# skipped when this flag is on (it would re-create jobs that just got nuked).
# RESET_ALL_JOBS_ON_STARTUP=false
